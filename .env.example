# opencode go API 密钥（必需）
OPENCODE_API_KEY=your-key-here

# opencode go 的基础端点（可选，有默认值）
# 网关内部会自动追加路径：OpenAI 格式 -> /chat/completions, Anthropic 格式 -> /messages
BASE_URL=https://opencode.ai/zen/go/v1

# 网关监听端口（可选，默认 3456）
LISTEN_PORT=3456

# 非流式请求超时（毫秒，可选，默认 120000）
# 仅作用于非流式请求；流式请求不设置总时长上限。
NON_STREAM_TIMEOUT_MS=120000

# 需要转换的模型列表（可选，默认包含常用 OpenAI 模型）
MODELS_NEED_TRANSFORMATION=deepseek-v4-pro,deepseek-v4-flash,glm-5.1,glm-5,kimi-k2.6,kimi-k2.5,qwen3.6-plus