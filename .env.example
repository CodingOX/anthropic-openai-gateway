# OpenAI API Key（必需，用于模型转换模式）
OPENAI_API_KEY=sk-your-key-here

# OpenAI 配置（可选，有默认值）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=120000

# Anthropic API Key（可选，用于透传模式）
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Anthropic 配置（可选，有默认值）
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_TIMEOUT_MS=120000

# 网关监听配置（可选，有默认值）
LISTEN_HOST=127.0.0.1
LISTEN_PORT=3456

# 需要转换的模型列表（逗号分隔）
MODELS_NEED_TRANSFORMATION=gpt-4.1,gpt-4o,gpt-4o-mini,gpt-4.1-mini,gpt-4.1-nano,gpt-5,o3,o3-mini,o4-mini

# 错误日志里的 prompt 预览配置
LOG_PROMPT_PREVIEW_ON_ERROR=false
PROMPT_PREVIEW_MAX_CHARS=240
